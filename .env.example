# ============================================================
# Minecraft Agent - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Minecraft Server Settings
# ------------------------------------------------------------

# Hostname or IP address of the Minecraft server
MC_SERVER_HOST=localhost

# Port the Minecraft server listens on (default Java Edition port)
MC_SERVER_PORT=25565

# In-game username the bot will use
MC_BOT_USERNAME=MinecraftAgent

# Authentication type: "offline" for cracked/LAN servers,
# "microsoft" for official Mojang/Microsoft accounts
MC_AUTH_TYPE=offline

# ------------------------------------------------------------
# LLM Provider Settings
# ------------------------------------------------------------

# Base URL for the OpenAI-compatible API endpoint.
# Examples:
#   OpenAI:    https://api.openai.com/v1
#   Ollama:    http://localhost:11434/v1
#   LM Studio: http://localhost:1234/v1
LLM_API_BASE=http://localhost:11434/v1

# API key for the LLM provider.
# For local providers (Ollama, LM Studio) any non-empty string works.
LLM_API_KEY=your-api-key-here

# Model identifier to use for chat completions.
# Examples: gpt-4o, gpt-4, llama3, mistral, gemma3
LLM_MODEL=gpt-4o

# Sampling temperature (0.0 = deterministic, 1.0 = very creative)
LLM_TEMPERATURE=0.7

# Maximum number of tokens to generate per response
LLM_MAX_TOKENS=150

# ------------------------------------------------------------
# Bot Behavior Settings
# ------------------------------------------------------------

# Minecraft username of the bot's owner.
# Only this player can issue privileged commands (e.g. "follow me").
BOT_OWNER=YourMinecraftUsername

# How many blocks away the bot tries to stay when following a player
FOLLOW_DISTANCE=2

# Delay in milliseconds before the bot sends a chat response.
# Helps avoid spam kicks on servers with rate limiting.
RESPONSE_DELAY_MS=1000

# Number of recent chat messages to include as context for the LLM.
# Higher values give more context but use more tokens.
CONTEXT_MESSAGE_COUNT=5
