# Minecraft server connection
MC_HOST=192.168.1.x
MC_PORT=25565
MC_USERNAME=AgentBot
MC_VERSION=1.21.1

# HTTP controller auth (Bearer token for /act-batch and /state)
MC_CONTROLLER_TOKEN=changeme

# OpenClaw Gateway (get token via: openclaw gateway --show-token)
OPENCLAW_TOKEN=
OPENCLAW_SESSION_KEY=main
# Docker only: service URL for the OpenClaw gateway (overridden in docker-compose.yml)
OPENCLAW_GATEWAY_URL=ws://openclaw:18789

# Controller HTTP port
CONTROLLER_PORT=3001
